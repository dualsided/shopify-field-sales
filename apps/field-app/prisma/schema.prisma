generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/field-app-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// SHOPIFY SESSION (for embedded app OAuth)
// ============================================

// Shopify OAuth Session storage (required by @shopify/shopify-app-session-storage-prisma)
// Field names/types are dictated by Shopify - only @map annotations can be added
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false) @map("is_online")
  scope               String?
  expires             DateTime?
  accessToken         String    @map("access_token")
  userId              BigInt?   @map("user_id")
  firstName           String?   @map("first_name")
  lastName            String?   @map("last_name")
  email               String?
  accountOwner        Boolean   @default(false) @map("account_owner")
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false) @map("email_verified")
  refreshToken        String?   @map("refresh_token")
  refreshTokenExpires DateTime? @map("refresh_token_expires")

  @@map("sessions")
}

// ============================================
// SHOP & AUTHENTICATION
// ============================================

model Shop {
  id                  String          @id @default(cuid())
  shopifyDomain       String          @unique @map("shopify_domain")
  shopName            String          @map("shop_name")
  accessToken         String          @map("access_token") // Encrypted Shopify offline access token
  scopes              String
  paymentStrategy     PaymentStrategy @default(SHOPIFY_TERMS) @map("payment_strategy")
  stripeAccountId     String?         @map("stripe_account_id") // For Stripe Connect
  config              Json?           // Additional shop configuration
  isActive            Boolean         @default(true) @map("is_active")
  // Shopify plan detection
  shopifyPlan         String?         @map("shopify_plan") // e.g., "Shopify Plus", "Basic", etc.
  hasManagedCompanies Boolean         @default(false) @map("has_managed_companies")
  planDetectedAt      DateTime?       @map("plan_detected_at")
  // Product inclusion settings
  productInclusionTag String?         @map("product_inclusion_tag") // Tag to auto-enable products (e.g., "field-sales")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  // Relations
  salesReps      SalesRep[]
  territories    Territory[]
  companies      Company[]
  paymentMethods PaymentMethod[]
  cartSessions   CartSession[]
  orders         Order[]
  products       Product[]
  promotions     Promotion[]
  quotas         RepQuota[]

  @@map("shops")
}

enum PaymentStrategy {
  SHOPIFY_TERMS @map("shopify_terms")
  STRIPE_VAULT  @map("stripe_vault")
  SHOPIFY_VAULT @map("shopify_vault")
}

model SalesRep {
  id           String   @id @default(cuid())
  shopId       String   @map("shop_id")
  email        String
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String?
  role         RepRole  @default(REP)
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  shop              Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repTerritories    RepTerritory[]
  assignedCompanies Company[]      @relation("AssignedRep")
  cartSessions      CartSession[]
  orders            Order[]
  quotas            RepQuota[]

  @@unique([shopId, email])
  @@index([shopId])
  @@map("sales_reps")
}

enum RepRole {
  REP     @map("rep")
  MANAGER @map("manager")
  ADMIN   @map("admin")
}

// ============================================
// TERRITORIES
// ============================================

model Territory {
  id          String   @id @default(cuid())
  shopId      String   @map("shop_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  shop           Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  zipcodes       TerritoryZipcode[]
  states         TerritoryState[]
  repTerritories RepTerritory[]
  companies      Company[]
  locations      CompanyLocation[]

  @@index([shopId])
  @@map("territories")
}

model TerritoryZipcode {
  id          String @id @default(cuid())
  territoryId String @map("territory_id")
  zipcode     String

  // Relations
  territory Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)

  @@unique([territoryId, zipcode])
  @@index([zipcode])
  @@map("territory_zipcodes")
}

model TerritoryState {
  id          String @id @default(cuid())
  territoryId String @map("territory_id")
  stateCode   String @map("state_code")  // e.g., "CA", "NY", "TX"
  stateName   String @map("state_name")  // e.g., "California", "New York"

  // Relations
  territory Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)

  @@unique([territoryId, stateCode])
  @@index([stateCode])
  @@map("territory_states")
}

model RepTerritory {
  id          String   @id @default(cuid())
  repId       String   @map("rep_id")
  territoryId String   @map("territory_id")
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  rep       SalesRep  @relation(fields: [repId], references: [id], onDelete: Cascade)
  territory Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)

  @@unique([repId, territoryId])
  @@map("rep_territories")
}

// ============================================
// COMPANIES
// shopifyCompanyId NULL = internal company (managed in app)
// shopifyCompanyId EXISTS = Shopify-managed company
// ============================================

model Company {
  id               String       @id @default(cuid())
  shopId           String       @map("shop_id")
  shopifyCompanyId String?      @map("shopify_company_id") // Shopify GID (null for internal companies)
  name             String
  accountNumber    String?      @map("account_number") // Manual entry
  paymentTerms     PaymentTerms @default(DUE_ON_ORDER) @map("payment_terms")
  territoryId      String?      @map("territory_id") // Auto-assigned based on zipcode
  assignedRepId    String?      @map("assigned_rep_id") // Manual rep assignment
  syncStatus       SyncStatus   @default(SYNCED) @map("sync_status")
  lastSyncedAt     DateTime?    @map("last_synced_at")
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  shop           Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  territory      Territory?        @relation(fields: [territoryId], references: [id])
  assignedRep    SalesRep?         @relation("AssignedRep", fields: [assignedRepId], references: [id])
  locations      CompanyLocation[]
  contacts       CompanyContact[]
  paymentMethods PaymentMethod[]
  cartSessions   CartSession[]
  orders         Order[]

  @@unique([shopId, shopifyCompanyId])
  @@unique([shopId, accountNumber])
  @@index([territoryId])
  @@index([assignedRepId])
  @@index([shopId, isActive])
  @@map("companies")
}

enum PaymentTerms {
  DUE_ON_ORDER @map("due_on_order")
  NET_15       @map("net_15")
  NET_30       @map("net_30")
  NET_45       @map("net_45")
  NET_60       @map("net_60")
}

enum SyncStatus {
  SYNCED     @map("synced")
  PENDING    @map("pending")
  SYNCING    @map("syncing")
  ERROR      @map("error")
  NOT_SYNCED @map("not_synced")
}

// ============================================
// COMPANY LOCATIONS
// ============================================

model CompanyLocation {
  id                String   @id @default(cuid())
  companyId         String   @map("company_id")
  shopifyLocationId String?  @map("shopify_location_id") // Shopify CompanyLocation GID
  territoryId       String?  @map("territory_id")
  name              String
  isPrimary         Boolean  @default(false) @map("is_primary")
  address1          String?
  address2          String?
  city              String?
  province          String?
  provinceCode      String?  @map("province_code") // e.g., "CA", "NY"
  zipcode           String?
  country           String   @default("US")
  countryCode       String   @default("US") @map("country_code")
  phone             String?
  isShippingAddress Boolean  @default(true) @map("is_shipping_address")
  isBillingAddress  Boolean  @default(true) @map("is_billing_address")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  company        Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  territory      Territory? @relation(fields: [territoryId], references: [id])
  shippingOrders Order[]    @relation("ShippingLocation")
  billingOrders  Order[]    @relation("BillingLocation")

  @@unique([companyId, shopifyLocationId])
  @@index([zipcode])
  @@index([territoryId])
  @@map("company_locations")
}

// ============================================
// COMPANY CONTACTS
// ============================================

model CompanyContact {
  id                String   @id @default(cuid())
  companyId         String   @map("company_id")
  shopifyContactId  String?  @map("shopify_contact_id") // Shopify CompanyContact GID
  shopifyCustomerId String?  @map("shopify_customer_id") // Shopify Customer GID (synced)
  firstName         String   @map("first_name")
  lastName          String   @map("last_name")
  email             String
  phone             String?
  title             String? // Job title
  isPrimary         Boolean  @default(false) @map("is_primary")
  canPlaceOrders    Boolean  @default(true) @map("can_place_orders")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  paymentMethods PaymentMethod[]
  orders         Order[]

  @@unique([companyId, email])
  @@unique([companyId, shopifyContactId])
  @@map("company_contacts")
}

// ============================================
// PAYMENTS
// ============================================

model PaymentMethod {
  id                 String          @id @default(cuid())
  shopId             String          @map("shop_id")
  companyId          String          @map("company_id")
  contactId          String?         @map("contact_id") // Optional: payment method owned by contact
  provider           PaymentProvider
  externalCustomerId String?         @map("external_customer_id") // Stripe customer ID, etc.
  externalMethodId   String          @map("external_method_id") // Stripe payment method ID, etc.
  last4              String?
  brand              String? // visa, mastercard, etc.
  expiryMonth        Int?            @map("expiry_month")
  expiryYear         Int?            @map("expiry_year")
  isDefault          Boolean         @default(false) @map("is_default")
  isActive           Boolean         @default(true) @map("is_active")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  // Relations
  shop    Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact CompanyContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([shopId, companyId, externalMethodId])
  @@index([companyId, isDefault])
  @@index([contactId])
  @@map("payment_methods")
}

enum PaymentProvider {
  STRIPE        @map("stripe")
  SHOPIFY_TERMS @map("shopify_terms")
  SHOPIFY_VAULT @map("shopify_vault")
}

// ============================================
// CART & ORDERS
// ============================================

model CartSession {
  id            String     @id @default(cuid())
  shopId        String     @map("shop_id")
  repId         String     @map("rep_id")
  companyId     String     @map("company_id")
  lineItems     Json       @map("line_items") // Array of { variantId, quantity, price, title, etc. }
  discountCodes String[]   @default([]) @map("discount_codes")
  notes         String?
  status        CartStatus @default(ACTIVE)
  expiresAt     DateTime   @map("expires_at")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  // Relations
  shop    Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  rep     SalesRep @relation(fields: [repId], references: [id], onDelete: Cascade)
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([shopId, repId])
  @@index([companyId])
  @@map("cart_sessions")
}

enum CartStatus {
  ACTIVE    @map("active")
  SUBMITTED @map("submitted")
  ABANDONED @map("abandoned")
}

model Order {
  id                  String      @id @default(cuid())
  shopId              String      @map("shop_id")
  companyId           String      @map("company_id")
  salesRepId          String      @map("sales_rep_id")
  contactId           String?     @map("contact_id")
  shippingLocationId  String?     @map("shipping_location_id")
  billingLocationId   String?     @map("billing_location_id")

  // Shopify integration
  shopifyDraftOrderId String?     @map("shopify_draft_order_id")  // GID when synced as draft
  shopifyOrderId      String?     @map("shopify_order_id")        // GID when order is placed
  shopifyOrderNumber  String?     @map("shopify_order_number")    // Human-readable order number

  // Order details
  orderNumber         String      @map("order_number")            // Internal order number
  status              OrderStatus @default(DRAFT)
  note                String?
  poNumber            String?     @map("po_number")               // Customer PO number

  // Totals (stored in cents to avoid floating point issues)
  subtotalCents       Int         @default(0) @map("subtotal_cents")
  discountCents       Int         @default(0) @map("discount_cents")
  shippingCents       Int         @default(0) @map("shipping_cents")
  taxCents            Int         @default(0) @map("tax_cents")
  totalCents          Int         @default(0) @map("total_cents")
  currency            String      @default("USD")

  // Payment
  paymentTerms        PaymentTerms @default(DUE_ON_ORDER) @map("payment_terms")
  paymentDueDate      DateTime?    @map("payment_due_date")
  paidAt              DateTime?    @map("paid_at")

  // Timestamps
  placedAt            DateTime?   @map("placed_at")               // When draft was converted to order
  cancelledAt         DateTime?   @map("cancelled_at")
  refundedAt          DateTime?   @map("refunded_at")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Relations
  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  company          Company          @relation(fields: [companyId], references: [id])
  salesRep         SalesRep         @relation(fields: [salesRepId], references: [id])
  contact          CompanyContact?  @relation(fields: [contactId], references: [id])
  shippingLocation CompanyLocation? @relation("ShippingLocation", fields: [shippingLocationId], references: [id])
  billingLocation  CompanyLocation? @relation("BillingLocation", fields: [billingLocationId], references: [id])
  lineItems        OrderLineItem[]

  @@unique([shopId, orderNumber])
  @@unique([shopId, shopifyDraftOrderId])
  @@unique([shopId, shopifyOrderId])
  @@index([shopId, status])
  @@index([companyId])
  @@index([salesRepId])
  @@index([createdAt])
  @@map("orders")
}

enum OrderStatus {
  DRAFT           @map("draft")            // Sales rep is building/editing the order
  AWAITING_REVIEW @map("awaiting_review")  // Submitted for admin approval
  PENDING         @map("pending")          // Approved and synced to Shopify as draft order
  PAID            @map("paid")             // Payment received
  CANCELLED       @map("cancelled")        // Order cancelled
  REFUNDED        @map("refunded")         // Order refunded
}

model OrderLineItem {
  id                    String   @id @default(cuid())
  orderId               String   @map("order_id")

  // Product info (denormalized for historical accuracy)
  shopifyProductId      String?  @map("shopify_product_id")      // GID
  shopifyVariantId      String?  @map("shopify_variant_id")      // GID
  sku                   String?
  title                 String                                   // Product title
  variantTitle          String?  @map("variant_title")           // Variant title (e.g., "Large / Blue")
  imageUrl              String?  @map("image_url")               // Product image for display

  // Quantity and pricing (cents)
  quantity              Int
  unitPriceCents        Int      @map("unit_price_cents")
  discountCents         Int      @default(0) @map("discount_cents")
  taxCents              Int      @default(0) @map("tax_cents")
  totalCents            Int      @map("total_cents")             // (unitPrice * quantity) - discount + tax

  // Fulfillment
  fulfilledQuantity     Int      @default(0) @map("fulfilled_quantity")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_line_items")
}

// ============================================
// PRODUCTS (synced from Shopify)
// ============================================

model Product {
  id               String   @id @default(cuid())
  shopId           String   @map("shop_id")
  shopifyProductId String   @map("shopify_product_id") // Shopify GID
  title            String
  description      String?
  imageUrl         String?  @map("image_url")
  productType      String?  @map("product_type")
  vendor           String?
  tags             String[] @default([])              // Shopify tags for inclusion matching
  status           ProductStatus @default(ACTIVE)
  isActive         Boolean  @default(true) @map("is_active")
  enabledForFieldApp Boolean @default(false) @map("enabled_for_field_app") // Manually or auto-enabled
  syncedAt         DateTime @map("synced_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@unique([shopId, shopifyProductId])
  @@index([shopId, status])
  @@index([shopId, isActive])
  @@index([shopId, enabledForFieldApp])
  @@map("products")
}

enum ProductStatus {
  ACTIVE   @map("active")
  ARCHIVED @map("archived")
  DRAFT    @map("draft")
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String   @map("product_id")
  shopifyVariantId  String   @map("shopify_variant_id") // Shopify GID
  title             String   // e.g., "Large / Blue"
  sku               String?
  priceCents        Int      @map("price_cents")
  comparePriceCents Int?     @map("compare_price_cents")
  imageUrl          String?  @map("image_url")
  inventoryQuantity Int?     @map("inventory_quantity")
  isAvailable       Boolean  @default(true) @map("is_available")
  position          Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, shopifyVariantId])
  @@index([sku])
  @@map("product_variants")
}

// ============================================
// PROMOTIONS (app-managed discounts)
// ============================================

model Promotion {
  id          String        @id @default(cuid())
  shopId      String        @map("shop_id")
  name        String        // "Summer Sale 10%"
  description String?
  type        PromotionType
  value       Decimal       @db.Decimal(10, 2) // 10.00 = 10% or $10

  // Conditions
  minQuantity   Int?      @map("min_quantity")     // Buy X+ items
  minOrderCents Int?      @map("min_order_cents")  // Orders over $X
  productIds    String[]  @default([]) @map("product_ids") // Specific products only (empty = all)

  // Buy X Get Y specific
  buyQuantity Int?     @map("buy_quantity")
  getQuantity Int?     @map("get_quantity")
  getDiscount Decimal? @map("get_discount") @db.Decimal(5, 2) // 100 = free, 50 = 50% off

  // Validity
  startsAt  DateTime  @map("starts_at")
  endsAt    DateTime? @map("ends_at")
  isActive  Boolean   @default(true) @map("is_active")
  priority  Int       @default(0) // Higher = applied first
  stackable Boolean   @default(false) // Can combine with other promos

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, isActive])
  @@index([startsAt, endsAt])
  @@map("promotions")
}

enum PromotionType {
  PERCENTAGE  @map("percentage")   // X% off
  FIXED_AMOUNT @map("fixed_amount") // $X off per item
  BUY_X_GET_Y @map("buy_x_get_y")  // Buy X get Y at discount
}

// ============================================
// QUOTAS
// ============================================

model RepQuota {
  id          String   @id @default(cuid())
  shopId      String   @map("shop_id")
  repId       String   @map("rep_id")
  year        Int
  month       Int      // 1-12
  targetCents Int      @map("target_cents")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  salesRep SalesRep @relation(fields: [repId], references: [id], onDelete: Cascade)

  @@unique([shopId, repId, year, month])
  @@index([shopId, year, month])
  @@index([repId])
  @@map("rep_quotas")
}
