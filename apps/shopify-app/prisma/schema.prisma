generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify OAuth Session storage (required by @shopify/shopify-app-session-storage-prisma)
// Field names/types are dictated by Shopify - only @map annotations can be added
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false) @map("is_online")
  scope               String?
  expires             DateTime?
  accessToken         String    @map("access_token")
  userId              BigInt?   @map("user_id")
  firstName           String?   @map("first_name")
  lastName            String?   @map("last_name")
  email               String?
  accountOwner        Boolean   @default(false) @map("account_owner")
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false) @map("email_verified")
  refreshToken        String?   @map("refresh_token")
  refreshTokenExpires DateTime? @map("refresh_token_expires")

  @@map("sessions")
}

// Shop model - created/updated on app install
// Matches the main-app Shop table (Prisma model renamed from Tenant to Shop)
model Shop {
  id                  String          @id @default(cuid())
  shopifyDomain       String          @unique @map("shopify_domain")
  shopName            String          @map("shop_name")
  accessToken         String          @map("access_token")
  scopes              String
  paymentStrategy     PaymentStrategy @default(SHOPIFY_TERMS) @map("payment_strategy")
  stripeAccountId     String?         @map("stripe_account_id")
  config              Json?
  isActive            Boolean         @default(true) @map("is_active")
  // Shopify plan detection
  shopifyPlan         String?         @map("shopify_plan")
  hasManagedCompanies Boolean         @default(false) @map("has_managed_companies")
  planDetectedAt      DateTime?       @map("plan_detected_at")
  // Product inclusion settings
  productInclusionTag String?         @map("product_inclusion_tag") // Tag to auto-enable products

  // Billing
  billingPlan           BillingPlan?   @map("billing_plan")
  billingStatus         BillingStatus  @default(INACTIVE) @map("billing_status")
  shopifySubscriptionId String?        @map("shopify_subscription_id")  // Shopify App Subscription GID
  subscriptionStatus    String?        @map("subscription_status")      // ACTIVE, CANCELLED, etc.
  currentPeriodStart    DateTime?      @map("current_period_start")
  currentPeriodEnd      DateTime?      @map("current_period_end")
  trialEndsAt           DateTime?      @map("trial_ends_at")

  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  // Relations
  products       Product[]
  quotas         RepQuota[]
  billingPeriods BillingPeriod[]

  @@map("shops")
}

enum PaymentStrategy {
  SHOPIFY_TERMS @map("shopify_terms")
  STRIPE_VAULT  @map("stripe_vault")
  SHOPIFY_VAULT @map("shopify_vault")
}

// ============================================
// BILLING
// ============================================

enum BillingPlan {
  BASIC @map("basic")
  GROW  @map("grow")
  PRO   @map("pro")
  PLUS  @map("plus")
}

enum BillingStatus {
  INACTIVE  @map("inactive")
  TRIAL     @map("trial")
  ACTIVE    @map("active")
  PAST_DUE  @map("past_due")
  CANCELLED @map("cancelled")
}

// Territory model - referenced for queries
model Territory {
  id          String   @id @default(cuid())
  shopId      String   @map("shop_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  zipcodes       TerritoryZipcode[]
  states         TerritoryState[]
  repTerritories RepTerritory[]
  locations      CompanyLocation[]

  @@index([shopId])
  @@map("territories")
}

model TerritoryZipcode {
  id          String @id @default(cuid())
  territoryId String @map("territory_id")
  zipcode     String

  territory Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)

  @@unique([territoryId, zipcode])
  @@index([zipcode])
  @@map("territory_zipcodes")
}

model TerritoryState {
  id           String @id @default(cuid())
  territoryId  String @map("territory_id")
  stateCode    String @map("state_code")  // e.g., "CA", "NY", "TX"
  stateName    String @map("state_name")  // e.g., "California", "New York", "Texas"

  territory Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)

  @@unique([territoryId, stateCode])
  @@index([stateCode])
  @@map("territory_states")
}

model RepTerritory {
  id          String   @id @default(cuid())
  repId       String   @map("rep_id")
  territoryId String   @map("territory_id")
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")

  rep       SalesRep  @relation(fields: [repId], references: [id], onDelete: Cascade)
  territory Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)

  @@unique([repId, territoryId])
  @@map("rep_territories")
}

// Company model - full model for company management
model Company {
  id               String       @id @default(cuid())
  shopId           String       @map("shop_id")
  shopifyCompanyId String?      @map("shopify_company_id")
  name             String
  accountNumber    String?      @map("account_number")
  paymentTerms     PaymentTerms @default(DUE_ON_ORDER) @map("payment_terms")
  assignedRepId    String?      @map("assigned_rep_id")
  syncStatus       SyncStatus   @default(SYNCED) @map("sync_status")
  lastSyncedAt     DateTime?    @map("last_synced_at")
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  assignedRep SalesRep?         @relation(fields: [assignedRepId], references: [id])
  locations   CompanyLocation[]
  contacts    CompanyContact[]
  orders      Order[]

  @@unique([shopId, shopifyCompanyId])
  @@unique([shopId, accountNumber])
  @@index([assignedRepId])
  @@map("companies")
}

enum PaymentTerms {
  DUE_ON_ORDER @map("due_on_order")
  NET_15       @map("net_15")
  NET_30       @map("net_30")
  NET_45       @map("net_45")
  NET_60       @map("net_60")
}

enum SyncStatus {
  PENDING    @map("pending")
  SYNCING    @map("syncing")
  SYNCED     @map("synced")
  ERROR      @map("error")
  NOT_SYNCED @map("not_synced")
}

// Sales Rep model for company assignment
model SalesRep {
  id            String    @id @default(cuid())
  shopId        String    @map("shop_id")
  email         String
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  role          RepRole   @default(REP)
  isActive      Boolean   @default(true) @map("is_active")

  // Billing tracking - when rep was activated/deactivated
  activatedAt   DateTime? @map("activated_at")
  deactivatedAt DateTime? @map("deactivated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companies      Company[]
  repTerritories RepTerritory[]
  orders         Order[]
  quotas         RepQuota[]

  @@unique([shopId, email])
  @@index([shopId])
  @@map("sales_reps")
}

enum RepRole {
  REP     @map("rep")
  MANAGER @map("manager")
}

// Company Location model
model CompanyLocation {
  id                String   @id @default(cuid())
  companyId         String   @map("company_id")
  shopifyLocationId String?  @map("shopify_location_id")
  territoryId       String?  @map("territory_id")
  name              String
  isPrimary         Boolean  @default(false) @map("is_primary")
  address1          String?
  address2          String?
  city              String?
  province          String?
  provinceCode      String?  @map("province_code")
  zipcode           String?
  country           String   @default("US")
  countryCode       String   @default("US") @map("country_code")
  phone             String?
  isShippingAddress Boolean  @default(true) @map("is_shipping_address")
  isBillingAddress  Boolean  @default(true) @map("is_billing_address")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  company        Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  territory      Territory? @relation(fields: [territoryId], references: [id])
  shippingOrders Order[]    @relation("ShippingLocation")
  billingOrders  Order[]    @relation("BillingLocation")

  @@unique([companyId, shopifyLocationId])
  @@index([zipcode])
  @@index([territoryId])
  @@map("company_locations")
}

// Company Contact model
model CompanyContact {
  id                String   @id @default(cuid())
  companyId         String   @map("company_id")
  shopifyContactId  String?  @map("shopify_contact_id")
  shopifyCustomerId String?  @map("shopify_customer_id")
  firstName         String   @map("first_name")
  lastName          String   @map("last_name")
  email             String
  phone             String?
  title             String?
  isPrimary         Boolean  @default(false) @map("is_primary")
  canPlaceOrders    Boolean  @default(true) @map("can_place_orders")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@unique([companyId, email])
  @@map("company_contacts")
}

// Order model - represents orders created by sales reps
model Order {
  id                  String      @id @default(cuid())
  shopId              String      @map("shop_id")
  companyId           String      @map("company_id")
  salesRepId          String      @map("sales_rep_id")
  contactId           String?     @map("contact_id")
  shippingLocationId  String?     @map("shipping_location_id")
  billingLocationId   String?     @map("billing_location_id")

  // Shopify integration
  shopifyDraftOrderId String?     @map("shopify_draft_order_id")  // GID when synced as draft
  shopifyOrderId      String?     @map("shopify_order_id")        // GID when order is placed
  shopifyOrderNumber  String?     @map("shopify_order_number")    // Human-readable order number

  // Order details
  orderNumber         String      @map("order_number")            // Internal order number
  status              OrderStatus @default(DRAFT)
  note                String?
  poNumber            String?     @map("po_number")               // Customer PO number

  // Totals (stored in cents to avoid floating point issues)
  subtotalCents       Int         @default(0) @map("subtotal_cents")
  discountCents       Int         @default(0) @map("discount_cents")
  shippingCents       Int         @default(0) @map("shipping_cents")
  taxCents            Int         @default(0) @map("tax_cents")
  totalCents          Int         @default(0) @map("total_cents")
  currency            String      @default("USD")

  // Payment
  paymentTerms        PaymentTerms @default(DUE_ON_ORDER) @map("payment_terms")
  paymentDueDate      DateTime?    @map("payment_due_date")
  paidAt              DateTime?    @map("paid_at")

  // Timestamps
  placedAt            DateTime?   @map("placed_at")               // When draft was converted to order
  cancelledAt         DateTime?   @map("cancelled_at")
  refundedAt          DateTime?   @map("refunded_at")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Relations
  company          Company          @relation(fields: [companyId], references: [id])
  salesRep         SalesRep         @relation(fields: [salesRepId], references: [id])
  contact          CompanyContact?  @relation(fields: [contactId], references: [id])
  shippingLocation CompanyLocation? @relation("ShippingLocation", fields: [shippingLocationId], references: [id])
  billingLocation  CompanyLocation? @relation("BillingLocation", fields: [billingLocationId], references: [id])
  lineItems        OrderLineItem[]
  billedOrder      BilledOrder?     // Revenue share billing record

  @@unique([shopId, orderNumber])
  @@unique([shopId, shopifyDraftOrderId])
  @@unique([shopId, shopifyOrderId])
  @@index([shopId, status])
  @@index([companyId])
  @@index([salesRepId])
  @@index([createdAt])
  @@map("orders")
}

enum OrderStatus {
  DRAFT           @map("draft")            // Sales rep is building/editing the order
  AWAITING_REVIEW @map("awaiting_review")  // Submitted for admin approval
  PENDING         @map("pending")          // Approved and synced to Shopify as draft order
  PAID            @map("paid")             // Payment received
  CANCELLED       @map("cancelled")        // Order cancelled
  REFUNDED        @map("refunded")         // Order refunded
}

// Order line item model
model OrderLineItem {
  id                    String   @id @default(cuid())
  orderId               String   @map("order_id")

  // Product info (denormalized for historical accuracy)
  shopifyProductId      String?  @map("shopify_product_id")      // GID
  shopifyVariantId      String?  @map("shopify_variant_id")      // GID
  sku                   String?
  title                 String                                   // Product title
  variantTitle          String?  @map("variant_title")           // Variant title (e.g., "Large / Blue")
  imageUrl              String?  @map("image_url")               // Product image for display

  // Quantity and pricing (cents)
  quantity              Int
  unitPriceCents        Int      @map("unit_price_cents")
  discountCents         Int      @default(0) @map("discount_cents")
  taxCents              Int      @default(0) @map("tax_cents")
  totalCents            Int      @map("total_cents")             // (unitPrice * quantity) - discount + tax

  // Fulfillment
  fulfilledQuantity     Int      @default(0) @map("fulfilled_quantity")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_line_items")
}

// ============================================
// PRODUCTS (synced from Shopify)
// ============================================

model Product {
  id               String        @id @default(cuid())
  shopId           String        @map("shop_id")
  shopifyProductId String        @map("shopify_product_id") // Shopify GID
  title            String
  description      String?
  imageUrl         String?       @map("image_url")
  productType      String?       @map("product_type")
  vendor           String?
  tags             String[]      @default([])              // Shopify tags for inclusion matching
  status           ProductStatus @default(ACTIVE)
  isActive         Boolean       @default(true) @map("is_active")
  enabledForFieldApp Boolean     @default(false) @map("enabled_for_field_app") // Manually or auto-enabled
  syncedAt         DateTime      @map("synced_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // Relations
  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@unique([shopId, shopifyProductId])
  @@index([shopId, status])
  @@index([shopId, isActive])
  @@index([shopId, enabledForFieldApp])
  @@map("products")
}

enum ProductStatus {
  ACTIVE   @map("active")
  ARCHIVED @map("archived")
  DRAFT    @map("draft")
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String   @map("product_id")
  shopifyVariantId  String   @map("shopify_variant_id") // Shopify GID
  title             String   // e.g., "Large / Blue"
  sku               String?
  priceCents        Int      @map("price_cents")
  comparePriceCents Int?     @map("compare_price_cents")
  imageUrl          String?  @map("image_url")
  inventoryQuantity Int?     @map("inventory_quantity")
  isAvailable       Boolean  @default(true) @map("is_available")
  position          Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, shopifyVariantId])
  @@index([sku])
  @@map("product_variants")
}

// ============================================
// QUOTAS
// ============================================

model RepQuota {
  id          String   @id @default(cuid())
  shopId      String   @map("shop_id")
  repId       String   @map("rep_id")
  year        Int
  month       Int      // 1-12
  targetCents Int      @map("target_cents")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  salesRep SalesRep @relation(fields: [repId], references: [id], onDelete: Cascade)

  @@unique([shopId, repId, year, month])
  @@index([shopId, year, month])
  @@index([repId])
  @@map("rep_quotas")
}

// ============================================
// BILLING PERIODS & USAGE
// ============================================

// Billing period - tracks usage for each billing cycle
model BillingPeriod {
  id                  String      @id @default(cuid())
  shopId              String      @map("shop_id")
  periodStart         DateTime    @map("period_start")
  periodEnd           DateTime    @map("period_end")
  plan                BillingPlan

  // Rep charges
  includedReps        Int         @map("included_reps")           // Reps included in base plan
  activeRepCount      Int         @default(0) @map("active_rep_count")
  extraRepCount       Int         @default(0) @map("extra_rep_count")
  perRepCents         Int         @map("per_rep_cents")           // Rate for this plan
  repChargesCents     Int         @default(0) @map("rep_charges_cents")

  // Revenue share
  orderRevenueCents   Int         @default(0) @map("order_revenue_cents")
  revenueSharePercent Float       @map("revenue_share_percent")   // e.g., 0.50 for 0.50%
  revenueShareCents   Int         @default(0) @map("revenue_share_cents")

  // Shopify usage record IDs
  repUsageRecordId    String?     @map("rep_usage_record_id")     // Shopify usage record GID
  revenueUsageRecordId String?    @map("revenue_usage_record_id") // Shopify usage record GID

  // Status
  status              String      @default("open")                // open, finalized, billed, failed
  finalizedAt         DateTime?   @map("finalized_at")

  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Relations
  shop   Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders BilledOrder[]

  @@unique([shopId, periodStart])
  @@index([shopId, status])
  @@map("billing_periods")
}

// BilledOrder - tracks which orders have been counted for revenue share
model BilledOrder {
  id                String   @id @default(cuid())
  billingPeriodId   String   @map("billing_period_id")
  orderId           String   @unique @map("order_id")
  totalCents        Int      @map("total_cents")
  revenueShareCents Int      @map("revenue_share_cents")
  billedAt          DateTime @default(now()) @map("billed_at")

  // Relations
  billingPeriod BillingPeriod @relation(fields: [billingPeriodId], references: [id], onDelete: Cascade)
  order         Order         @relation(fields: [orderId], references: [id])

  @@index([billingPeriodId])
  @@map("billed_orders")
}
